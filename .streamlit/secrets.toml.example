# ──────────────────────────────────────────────────────────────────────────────
# EXAMPLE: .streamlit/secrets.toml
# Copy this file → rename to secrets.toml → fill in real values.
# secrets.toml is in .gitignore — do NOT commit it.
#
# For Streamlit Community Cloud:
#   App dashboard → Settings → Secrets → paste content below (without comments)
# ──────────────────────────────────────────────────────────────────────────────

[gdrive]
# --- Service Account credentials (from Google Cloud Console) ---
project_id      = "your-project-id"
private_key_id  = "abc123def456..."
private_key     = "-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
client_email    = "your-sa@your-project.iam.gserviceaccount.com"
client_id       = "123456789012345678901"

# --- Google Drive folder ID ---
# Share this folder with client_email (Editor role).
# The folder ID is the last part of the Drive URL:
#   https://drive.google.com/drive/folders/THIS_PART_HERE
folder_id = "1aBcDeFgHiJkLmNoPqRsTuVwXyZ"
